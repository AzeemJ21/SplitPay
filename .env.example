STORE_URL="http://localhost:3001"
# Optional: AI dispute summaries (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
# e.g. claude-sonnet-4-20250514 (default) or claude-3-5-haiku-20241022
ANTHROPIC_MODEL=claude-sonnet-4-20250514
